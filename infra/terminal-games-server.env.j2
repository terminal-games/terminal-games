{{ ansible_managed | comment }}

PEER_LISTEN_ADDR=0.0.0.0:3000
SSH_LISTEN_ADDR=0.0.0.0:22
WEB_LISTEN_ADDR=0.0.0.0:443
WEB_TLS_CERT_PATH=/etc/terminal-games/certs/terminalgames.net.crt
WEB_TLS_KEY_PATH=/etc/terminal-games/certs/terminalgames.net.key
MESH_PINNED_PEM={{ MESH_PINNED_PEM }}
MESH_PINNED_PEM_BASE64={{ MESH_PINNED_PEM }}
LIBSQL_AUTH_TOKEN={{ LIBSQL_AUTH_TOKEN }}
LIBSQL_URL={{ LIBSQL_URL }}
ADMIN_SHARED_SECRET={{ ADMIN_SHARED_SECRET }}
AUTHOR_ENV_SECRET_KEY={{ AUTHOR_ENV_SECRET_KEY }}
METRICS_BEARER_TOKEN={{ METRICS_BEARER_TOKEN }}
SSH_HOST_KEY_BASE64={{ SSH_HOST_KEY_BASE64 }}
{% if DISCORD_WEBHOOK_URL is defined and DISCORD_WEBHOOK_URL | length > 0 %}
DISCORD_WEBHOOK_URL={{ DISCORD_WEBHOOK_URL }}
{% endif %}
SSH_CAPTCHA_THRESHOLD=0.5
MAX_ACTIVE_APPS={{ hostvars[inventory_hostname].max_active_apps }}
MAX_ACTIVE_APPS_PER_IP={{ hostvars[inventory_hostname].max_active_apps_per_ip | default(3) }}
MAX_QUEUED_APPS_PER_IP={{ hostvars[inventory_hostname].max_queued_apps_per_ip | default(3) }}
KV_LEADER_NODE_ID={{ hostvars[inventory_hostname].kv_leader_node_id }}
{% if hostvars[inventory_hostname].node_id == hostvars[inventory_hostname].kv_leader_node_id %}
KV_BACKEND={{ KV_BACKEND | default("libsql") }}
KV_APP_MAX_BYTES={{ KV_APP_MAX_BYTES | default(268435456) }}
KV_CACHE_DIR={{ KV_CACHE_DIR | default("/opt/terminal-games/kv-cache") }}
KV_CACHE_MEMORY_BYTES={{ KV_CACHE_MEMORY_BYTES | default(268435456) }}
KV_CACHE_DISK_BYTES={{ KV_CACHE_DISK_BYTES | default(34359738368) }}
{% if (KV_BACKEND | default("libsql")) == "s3" %}
KV_S3_BUCKET={{ KV_S3_BUCKET }}
KV_S3_PREFIX={{ KV_S3_PREFIX | default("kv") }}
{% if KV_S3_REGION | default('') | length > 0 %}
KV_S3_REGION={{ KV_S3_REGION }}
AWS_REGION={{ KV_S3_REGION }}
AWS_DEFAULT_REGION={{ KV_S3_REGION }}
{% endif %}
{% if KV_S3_ENDPOINT_URL | default('') | length > 0 %}
KV_S3_ENDPOINT_URL={{ KV_S3_ENDPOINT_URL }}
{% endif %}
{% if AWS_ACCESS_KEY_ID is defined and AWS_ACCESS_KEY_ID | length > 0 %}
AWS_ACCESS_KEY_ID={{ AWS_ACCESS_KEY_ID }}
{% endif %}
{% if AWS_SECRET_ACCESS_KEY is defined and AWS_SECRET_ACCESS_KEY | length > 0 %}
AWS_SECRET_ACCESS_KEY={{ AWS_SECRET_ACCESS_KEY }}
{% endif %}
{% if AWS_SESSION_TOKEN is defined and AWS_SESSION_TOKEN | length > 0 %}
AWS_SESSION_TOKEN={{ AWS_SESSION_TOKEN }}
{% endif %}
{% else %}
KV_LIBSQL_PATH={{ KV_LIBSQL_PATH | default("/var/lib/terminal-games/kv/kv.db") }}
{% endif %}
{% endif %}
NODE_ID={{ hostvars[inventory_hostname].node_id }}
NODE_REGION={{ hostvars[inventory_hostname].node_region }}
NODE_REGION_NAME={{ hostvars[inventory_hostname].node_region_name }}
NODE_LATITUDE={{ hostvars[inventory_hostname].node_latitude }}
NODE_LONGITUDE={{ hostvars[inventory_hostname].node_longitude }}
PEER_NODES={% for peer in groups['all'] if peer != inventory_hostname %}{{ hostvars[peer].node_id }}:{{ hostvars[peer].ansible_host }}:3000{% if not loop.last %},{% endif %}{% endfor %}
